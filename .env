# ── MailTester API Keys ──
#
# Format: key:plan,key:plan,...
# Plans:  pro | ultimate | ultimate_2x
#
# Examples:
#   Single key:
#     MAILTESTER_KEYS=sub_abc123:ultimate
#
#   Two keys (your current setup):
#     MAILTESTER_KEYS=sub_xxx:ultimate,sub_yyy:ultimate_2x
#
#   Scale up — add more keys anytime:
#     MAILTESTER_KEYS=sub_a:ultimate,sub_b:ultimate_2x,sub_c:ultimate_2x,sub_d:ultimate
#
# Throughput scales automatically:
#   1 ultimate                  =   353 req/min  (  500K/day)
#   1 ultimate_2x               =   682 req/min  (   1M/day)
#   1 ultimate + 1 ultimate_2x  = 1,035 req/min  ( 1.5M/day)
#   2 ultimate + 2 ultimate_2x  = 2,069 req/min  (   3M/day)

MAILTESTER_KEYS=sub_1T5K4vAJu6gy4fiY5aBNMwRJ:ultimate,sub_1TA4lLAJu6gy4fiYm1ogYwqt:ultimate_2x

# ── MailTester API endpoint (usually no need to change) ──
MAILTESTER_BASE_URL=https://happy.mailtester.ninja/ninja

# ── Concurrency ──
# Number of parallel verification slots.
# Recommended: ceil(total_req_per_sec × 1.3)
#   1 ultimate + 1 ultimate_2x = 17.1 req/s → COMBO_BATCH_SIZE=22
#   2 ultimate + 2 ultimate_2x = 34.5 req/s → COMBO_BATCH_SIZE=45
COMBO_BATCH_SIZE=22

BOUNCEBAN_API_KEY=36b2e2f71e378e5b016c1a2523485d27

# ── Server ──
PORT=3000